APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SENTRY_LARAVEL_DSN-null

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=null

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

NEON_BASE_URL=null
NEON_API_KEY=null

# OAuth helper port for Dropbox authorize/callback routes (published on host interfaces by Docker).
# This is reachable on your LAN unless your host firewall/network policy restricts it.
# Keep DROPBOX_REDIRECT_URI host:port aligned with this value.
# For local development, use http://localhost:8080/dropbox/callback.
# For LAN/NAS use, run setup-dropbox-local-https.sh and use an https hostname instead.
DROPBOX_AUTH_PORT=8080
DROPBOX_AUTH_HTTPS_PORT=8443
DROPBOX_APP_KEY=your_dropbox_app_key_here
DROPBOX_APP_SECRET=your_dropbox_app_secret_here
DROPBOX_REDIRECT_URI=http://localhost:8080/dropbox/callback
# DROPBOX_REDIRECT_URI=https://gooddads.localtest.me:8443/dropbox/callback

# Require HTTP Basic Auth for Dropbox OAuth routes by default
DROPBOX_OAUTH_REQUIRE_BASIC_AUTH=true
DROPBOX_OAUTH_BASIC_USER=dropbox-admin
DROPBOX_OAUTH_BASIC_PASSWORD=change-me
DROPBOX_UPLOAD_PATH=/uploads
